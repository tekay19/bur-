// AstroTransit AI — Prisma şeması
// PostgreSQL (Neon / Supabase) ile uyumludur.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserChart {
  id                String   @id @default(cuid())
  name              String
  gender            String?
  birthDate         String // ISO yyyy-MM-dd
  birthTime         String? // HH:mm
  birthPlace        String
  latitude          Float
  longitude         Float
  timezone          String
  birthTimeAccuracy String // "exact" | "approx" | "unknown"
  focusArea         String // "general" | "career" | "exam" | ...
  ownerKey          String? // oluşturan: üye uid veya misafir aid (IDOR koruması)
  createdAt         DateTime @default(now())

  results   ChartResult[]
  snapshots TransitSnapshot[]

  @@index([ownerKey])
}

model ChartResult {
  id                    String   @id @default(cuid())
  userChartId           String
  natalJson             Json
  transitJson           Json
  scoresJson            Json
  aiInterpretationJson  Json
  createdAt             DateTime @default(now())

  userChart UserChart @relation(fields: [userChartId], references: [id], onDelete: Cascade)

  @@index([userChartId])
}

model TransitSnapshot {
  id          String   @id @default(cuid())
  userChartId String
  date        String // ISO yyyy-MM-dd
  transitJson Json
  createdAt   DateTime @default(now())

  userChart UserChart @relation(fields: [userChartId], references: [id], onDelete: Cascade)

  @@index([userChartId, date])
}

// Üye — e-posta + şifre (Google yok). Krediler/plan üyede tutulur.
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  name           String?
  credits        Int      @default(0)
  plan           String   @default("free") // free | premium
  totalSpent     Int      @default(0)
  totalPurchased Int      @default(0)
  sign           String?  // kayıtlı güneş burcu (günlük yorum için)
  dailyEmail     Boolean  @default(false) // günlük yorum e-posta hatırlatması
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Şifre sıfırlama token'ı — e-posta linkindeki ham token'ın sha256 hash'i
// saklanır (DB sızsa bile token kullanılamaz). Tek kullanımlık + süreli.
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique // sha256(ham token)
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// İşlenmiş ödeme — order_id başına bir kez kredi yüklenir (idempotensi).
// Webhook ve dönüş URL'i aynı ödemeyi iki kez bildirebilir; bu tablo çift
// kredi yüklemeyi önler (id = Creem order_id, yoksa checkout_id).
model ProcessedPayment {
  id        String   @id // creem order_id / checkout_id
  credits   Int
  recipient String // "user:<uid>" | "guest:<aid>"
  createdAt DateTime @default(now())
}

// Üyeliksiz kredi hesabı — anonim çerez (aid) ile eşleşir
model CreditAccount {
  id             String   @id // anonim id (aid çerezi)
  credits        Int      @default(1) // yeni ziyaretçi 1 ücretsiz analiz
  totalSpent     Int      @default(0)
  totalPurchased Int      @default(0)
  recoveryCode   String   @unique // çerez silinirse geri yükleme
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
