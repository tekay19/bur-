# ============================================================
# AstroTransit AI — Ortam Değişkenleri
# Bu dosyayı ".env" olarak kopyalayın ve değerleri doldurun.
# ============================================================

# --- Veritabanı (PostgreSQL / Neon / Supabase) ---
# Boş bırakılırsa uygulama otomatik olarak bellek-içi (in-memory)
# depolama kullanır. Üretimde mutlaka gerçek bir bağlantı verin.
# Neon örneği:  postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/db?sslmode=require
# Supabase örneği: postgresql://postgres:[pass]@db.xxx.supabase.co:5432/postgres
DATABASE_URL=

# --- AI Yorumlama (OpenAI uyumlu API) ---
# Boş bırakılırsa kural-tabanlı (rule-based) yedek yorum üreticisi devreye girer.
#
# >>> GEMINI (önerilen) <<<
# Google AI Studio'dan ücretsiz anahtar: https://aistudio.google.com/apikey
# Gemini'nin OpenAI uyumlu endpoint'i kullanılır:
AI_API_KEY=
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_MODEL=gemini-2.5-flash
# Alternatif Gemini modelleri: gemini-2.0-flash (daha hızlı/ucuz), gemini-2.5-pro (daha güçlü)
#
# Diğer OpenAI uyumlu sağlayıcılar için örnekler:
# OpenAI:      AI_BASE_URL=https://api.openai.com/v1            AI_MODEL=gpt-4o-mini
# OpenRouter:  AI_BASE_URL=https://openrouter.ai/api/v1         AI_MODEL=...
# Together:    AI_BASE_URL=https://api.together.xyz/v1          AI_MODEL=...
#
# Not: GEMINI_API_KEY adıyla da çalışır (AI_API_KEY yoksa ona düşer).

# --- Astroloji Hesaplama Adapteri ---
# Seçenekler: "local" (varsayılan, native binary gerektirmez)
#             "external" (harici efemeris API)
#             "swiss" (gelecekteki Swiss Ephemeris adapteri — henüz pasif)
ASTRO_ADAPTER=local

# Harici efemeris adapteri kullanılacaksa:
ASTRO_EXTERNAL_API_URL=
ASTRO_EXTERNAL_API_KEY=

# --- Geocoding (şehir/ilçe -> enlem/boylam/timezone) ---
# Varsayılan: Open-Meteo Geocoding API (ÜCRETSİZ, ANAHTAR GEREKTİRMEZ).
#   Tüm Türkiye ilçe/kasabaları + dünya şehirlerini kapsar, timezone'u da döndürür.
#   Hiçbir şey ayarlamana gerek yok.
# Aşağıdakini DOLDURURSAN OpenCage uyumlu servis devreye girer (override):
GEOCODING_API_URL=
GEOCODING_API_KEY=

# --- Oturum imzalama (ZORUNLU - üretim) ---
# JWT (HS256) oturum çerezini imzalar. Üretimde mutlaka uzun, rastgele bir
# değer ver; yoksa tüm oturumlar reddedilir. Örn: `openssl rand -hex 32`
SESSION_SECRET=

# --- Site URL (e-posta linkleri + SEO) ---
# Şifre sıfırlama gibi mutlak linkler bununla kurulur. Boşsa https://astrotek.ai.
# Yerelde: http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# --- Ödeme (Creem.io — merchant of record) ---
# Boş bırakılırsa ödeme devre dışı (lokal/test'te kredi doğrudan eklenir,
# üretimde satın alma kapalı). API anahtarı creem_test_ ile başlarsa test
# endpoint'i otomatik kullanılır (test-api.creem.io); değilse canlı.
CREEM_API_KEY=
# İsteğe bağlı: endpoint'i elle zorla (genelde gerek yok).
# CREEM_API_URL=https://test-api.creem.io
# Ürün ID'leri (Creem panelinde oluşturulan ürünler). Boşsa yerleşik test
# ürünleri kullanılır. CANLIDA kendi ürün ID'lerini ver:
CREEM_PRODUCT_PACK3=
CREEM_PRODUCT_PACK10=
# Webhook imza sırrı (Creem panel > Developers > Webhooks). Boşsa webhook
# devre dışı; kredi yine dönüş URL'i ile yüklenir (yeterli ama webhook
# daha güvenilir bir yedektir). Webhook URL'i: <site>/api/webhooks/creem
CREEM_WEBHOOK_SECRET=

# --- SMTP (e-posta gönderimi: hoş geldin + şifre sıfırlama) ---
# Boş bırakılırsa e-posta GÖNDERİLMEZ; içerik (ve sıfırlama linki) sunucu
# konsoluna loglanır (geliştirme/test için yeterli).
# Sağlayıcı bağımsız: Gmail, Brevo, Resend SMTP, Mailtrap, Ethereal, vb.
SMTP_HOST=
SMTP_PORT=587
# SMTP_SECURE=true  -> 465 (SSL). Boş/false -> 587 (STARTTLS).
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# Gönderen adresi (örn. "Astrotek AI <no-reply@astrotek.ai>")
SMTP_FROM=

# --- Süperadmin paneli (/yonetim) ---
# Virgülle ayrık e-posta listesi. Bu e-postalarla KAYITLI + GİRİŞ yapmış
# üyeler yönetim panelini (/yonetim) görür ve kredi/plan/analiz yönetir.
# Boşsa panel kimseye açılmaz. Örn: ben@site.com, ortak@site.com
ADMIN_EMAILS=

# --- Günlük yorum e-posta cron'u ---
# Vercel Cron her sabah /api/cron/daily-horoscope'u çağırır (vercel.json).
# Vercel, CRON_SECRET ayarlıysa "Authorization: Bearer <CRON_SECRET>" gönderir.
# Manuel tetik: /api/cron/daily-horoscope?key=<CRON_SECRET>. `openssl rand -hex 24`
CRON_SECRET=
